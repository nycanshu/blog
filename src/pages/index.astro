---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Reveal from "@/components/Reveal.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { getBase } from "@/utils/getBase";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <!-- ===== HERO: The Portal ===== -->
    <section id="hero" class="relative overflow-hidden min-h-[50vh] sm:min-h-[70vh] flex items-center justify-center">
      <!-- Subtle glow accents behind the grid -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="glow-orb absolute top-[20%] left-[15%] w-64 h-64 sm:w-72 sm:h-72 rounded-full bg-accent/8 blur-[100px]"></div>
        <div class="glow-orb absolute bottom-[15%] right-[10%] w-72 h-72 sm:w-96 sm:h-96 rounded-full bg-accent/6 blur-[120px]" style="animation-delay: -2s;"></div>
      </div>

      <div class="relative z-10 app-layout text-center py-16 sm:py-24 lg:py-32">
        <Reveal>
          <h1 class="text-3xl sm:text-5xl lg:text-7xl font-bold tracking-tight leading-tight">
            <span class="text-foreground">hey, i'm </span>
            <span class="bg-gradient-to-r from-accent to-purple-400 bg-clip-text text-transparent">nycanshu</span><span class="text-accent">.</span>
          </h1>
        </Reveal>
        <Reveal delay={0.1}>
          <p class="mt-4 sm:mt-6 text-base sm:text-lg lg:text-xl text-foreground/60 max-w-2xl mx-auto leading-relaxed">
            Software engineer who builds things, breaks things, and writes about why they broke — solving problems that shouldn't be this hard.
          </p>
        </Reveal>
        <Reveal delay={0.18}>
          <p class="mt-3 text-sm sm:text-base text-accent/70 max-w-xl mx-auto italic">
            So you can skip the suffering and go straight to the fix.
          </p>
        </Reveal>
        <Reveal delay={0.2} class="mt-6 sm:mt-8 flex items-center justify-center gap-4">
          {
            SOCIALS.length > 0 && (
              <Socials />
            )
          }
          <a
            target="_blank"
            href={getBase("/rss.xml")}
            class="inline-flex items-center gap-1.5 text-foreground/50 hover:text-accent transition-colors duration-200"
            aria-label="rss feed"
            title="RSS Feed"
          >
            <IconRss
              width={18}
              height={18}
              class="stroke-current stroke-2"
            />
          </a>
        </Reveal>
      </div>
    </section>

    <!-- ===== FEATURED POSTS ===== -->
    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class="app-layout pt-12 sm:pt-16 pb-8"
        >
          <Reveal>
            <h2 class="text-xs font-semibold uppercase tracking-[0.2em] text-accent mb-8">
              Featured
            </h2>
          </Reveal>
          <ul class="grid gap-4">
            {featuredPosts.map((data, i) => (
              <Reveal delay={i * 0.08}>
                <Card variant="h3" {...data} />
              </Reveal>
            ))}
          </ul>
        </section>
      )
    }

    <!-- ===== RECENT POSTS ===== -->
    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="app-layout pt-12 pb-8">
          <Reveal>
            <h2 class="text-xs font-semibold uppercase tracking-[0.2em] text-accent mb-8">
              Recent
            </h2>
          </Reveal>
          <ul class="grid gap-4">
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && (
                  <Reveal delay={index * 0.08}>
                    <Card variant="h3" {...data} />
                  </Reveal>
                )
            )}
          </ul>
        </section>
      )
    }

    <Reveal class="app-layout my-12 text-center">
      <LinkButton href={getBase("/posts/")} class="inline-flex items-center gap-2 px-6 py-3 rounded-full glass text-foreground font-medium hover:text-accent transition-colors duration-200">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </Reveal>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
