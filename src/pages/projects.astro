---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
import { PROJECT_SECTIONS } from "@/config/projects";
---

<Layout title={`Projects | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout py-8 sm:py-12">
    <div class="reveal">
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold">Projects</h1>
      <p class="mt-2 text-sm sm:text-base text-foreground/60">Things I've built, shipped, and maintain.</p>
    </div>

    {PROJECT_SECTIONS.map((section, si) => (
      <section class="mt-10 sm:mt-14">
        <div class="reveal" style={`transition-delay: ${si * 0.05}s;`}>
          <h2 class="text-xs font-semibold uppercase tracking-[0.2em] text-accent mb-6">
            {section.label}
          </h2>
        </div>

        <ul class="grid gap-3">
          {section.projects.map((project, pi) => (
            <li class="reveal" style={`transition-delay: ${(si * 0.05) + (pi * 0.06)}s;`}>
              <div class="group rounded-xl p-4 sm:p-5 -mx-1 transition-all duration-200 hover:bg-accent/5 hover:shadow-[0_0_30px_-5px] hover:shadow-accent/10 border border-transparent hover:border-border">
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0 flex-1">
                    <h3 class="text-base sm:text-lg font-semibold text-foreground group-hover:text-accent transition-colors duration-200 truncate">
                      {project.title}
                    </h3>
                    <p class="mt-1 text-sm text-foreground/55 leading-relaxed line-clamp-2">
                      {project.description}
                    </p>
                  </div>
                </div>

                <div class="mt-3 flex flex-wrap items-center gap-2">
                  {project.tags.map(tag => (
                    <span class="text-[11px] px-2 py-0.5 rounded-full bg-accent/10 text-accent/70">
                      {tag}
                    </span>
                  ))}

                  <span class="flex-1"></span>

                  {project.url && (
                    <a
                      href={project.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs text-foreground/40 hover:text-accent transition-colors duration-200"
                      title="View source"
                    >
                      GitHub &nearr;
                    </a>
                  )}
                  {project.docs && (
                    <a
                      href={project.docs}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs text-foreground/40 hover:text-accent transition-colors duration-200"
                      title="Documentation"
                    >
                      Docs &nearr;
                    </a>
                  )}
                  {project.live && (
                    <a
                      href={project.live}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs text-foreground/40 hover:text-accent transition-colors duration-200"
                      title="Live demo"
                    >
                      Live &nearr;
                    </a>
                  )}
                </div>
              </div>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </main>
  <Footer />
</Layout>
