---
/**
 * Interactive grid background with dots + lines.
 * Dots near the cursor glow with accent color.
 * Uses lerping for smooth, floating mouse tracking.
 * Respects prefers-reduced-motion and theme changes.
 */
---

<canvas id="grid-canvas" class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"></canvas>

<script>
  function initGrid() {
    const canvas = document.getElementById("grid-canvas") as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const CELL_SIZE = 40;
    const DOT_RADIUS = 1;
    const HOVER_RADIUS = 180;
    const LERP_SPEED = 0.08; // lower = smoother/slower trailing

    // Real mouse position and smoothed (lerped) position
    let rawMouseX = -1000;
    let rawMouseY = -1000;
    let smoothX = -1000;
    let smoothY = -1000;
    let animationId: number;

    function lerp(a: number, b: number, t: number) {
      return a + (b - a) * t;
    }

    // Smooth sine-based easing — feels organic, not harsh
    function easeOutSine(x: number) {
      return Math.sin((x * Math.PI) / 2);
    }

    function getColors() {
      const isDark = document.documentElement.getAttribute("data-theme") === "dark"
        || (!document.documentElement.getAttribute("data-theme")
          && window.matchMedia("(prefers-color-scheme: dark)").matches);

      return {
        line: isDark ? "rgba(30, 42, 58, 0.25)" : "rgba(226, 224, 240, 0.4)",
        dot: isDark ? "rgba(30, 42, 58, 0.4)" : "rgba(226, 224, 240, 0.5)",
        glow: isDark ? "167, 139, 250" : "124, 91, 240",
      };
    }

    let colors = getColors();

    function resize() {
      const rect = canvas.parentElement?.getBoundingClientRect();
      if (!rect) return;
      const dpr = window.devicePixelRatio || 1;
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = `${rect.width}px`;
      canvas.style.height = `${rect.height}px`;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function draw() {
      const w = canvas.width / (window.devicePixelRatio || 1);
      const h = canvas.height / (window.devicePixelRatio || 1);
      ctx!.clearRect(0, 0, w, h);

      // Lerp mouse position for smooth trailing
      smoothX = lerp(smoothX, rawMouseX, LERP_SPEED);
      smoothY = lerp(smoothY, rawMouseY, LERP_SPEED);

      const cols = Math.ceil(w / CELL_SIZE) + 1;
      const rows = Math.ceil(h / CELL_SIZE) + 1;
      const offsetX = (w % CELL_SIZE) / 2;
      const offsetY = (h % CELL_SIZE) / 2;

      // Draw grid lines with subtle hover glow
      ctx!.lineWidth = 0.5;
      for (let i = 0; i <= cols; i++) {
        const x = offsetX + i * CELL_SIZE;
        const dist = Math.abs(x - smoothX);

        if (!prefersReducedMotion && dist < HOVER_RADIUS) {
          const t = easeOutSine(1 - dist / HOVER_RADIUS);
          ctx!.strokeStyle = `rgba(${colors.glow}, ${t * 0.15})`;
        } else {
          ctx!.strokeStyle = colors.line;
        }
        ctx!.beginPath();
        ctx!.moveTo(x, 0);
        ctx!.lineTo(x, h);
        ctx!.stroke();
      }

      for (let j = 0; j <= rows; j++) {
        const y = offsetY + j * CELL_SIZE;
        const dist = Math.abs(y - smoothY);

        if (!prefersReducedMotion && dist < HOVER_RADIUS) {
          const t = easeOutSine(1 - dist / HOVER_RADIUS);
          ctx!.strokeStyle = `rgba(${colors.glow}, ${t * 0.15})`;
        } else {
          ctx!.strokeStyle = colors.line;
        }
        ctx!.beginPath();
        ctx!.moveTo(0, y);
        ctx!.lineTo(w, y);
        ctx!.stroke();
      }

      // Draw dot intersections with smooth glow
      for (let i = 0; i <= cols; i++) {
        for (let j = 0; j <= rows; j++) {
          const x = offsetX + i * CELL_SIZE;
          const y = offsetY + j * CELL_SIZE;

          const dx = x - smoothX;
          const dy = y - smoothY;
          const dist = Math.sqrt(dx * dx + dy * dy);

          let radius = DOT_RADIUS;
          let fillStyle = colors.dot;

          if (!prefersReducedMotion && dist < HOVER_RADIUS) {
            const t = easeOutSine(1 - dist / HOVER_RADIUS);
            radius = DOT_RADIUS + t * 3;
            const alpha = 0.15 + t * 0.85;
            fillStyle = `rgba(${colors.glow}, ${alpha})`;
          }

          ctx!.beginPath();
          ctx!.arc(x, y, radius, 0, Math.PI * 2);
          ctx!.fillStyle = fillStyle;
          ctx!.fill();
        }
      }
    }

    function onMouseMove(e: MouseEvent) {
      const rect = canvas.getBoundingClientRect();
      rawMouseX = e.clientX - rect.left;
      rawMouseY = e.clientY - rect.top;
    }

    function onMouseLeave() {
      // Lerp will smoothly drift away instead of snapping
      rawMouseX = -1000;
      rawMouseY = -1000;
    }

    function animate() {
      draw();
      animationId = requestAnimationFrame(animate);
    }

    // Setup
    resize();

    if (prefersReducedMotion) {
      draw();
    } else {
      const parent = canvas.parentElement;
      if (parent) {
        parent.style.pointerEvents = "auto";
        parent.addEventListener("mousemove", onMouseMove);
        parent.addEventListener("mouseleave", onMouseLeave);
      }
      animate();
    }

    const resizeObserver = new ResizeObserver(() => {
      resize();
      if (prefersReducedMotion) draw();
    });
    if (canvas.parentElement) {
      resizeObserver.observe(canvas.parentElement);
    }

    const themeObserver = new MutationObserver(() => {
      colors = getColors();
      if (prefersReducedMotion) draw();
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });

    document.addEventListener("astro:before-swap", () => {
      cancelAnimationFrame(animationId);
      resizeObserver.disconnect();
      themeObserver.disconnect();
      const parent = canvas.parentElement;
      if (parent) {
        parent.removeEventListener("mousemove", onMouseMove);
        parent.removeEventListener("mouseleave", onMouseLeave);
      }
    }, { once: true });
  }

  initGrid();
  document.addEventListener("astro:page-load", initGrid);
</script>
