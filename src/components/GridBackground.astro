---
/**
 * Interactive grid background — fixed, full-page.
 * Spring physics dots glow and push away from cursor anywhere on the page.
 * Lives in Layout.astro so it spans all pages.
 */
---

<canvas id="grid-canvas" class="fixed inset-0 w-full h-full pointer-events-none" style="z-index: 0;" aria-hidden="true"></canvas>

<script>
  function initGrid() {
    const canvas = document.getElementById("grid-canvas") as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isMobile = window.matchMedia("(max-width: 768px)").matches;

    const CELL_SIZE = isMobile ? 50 : 44;
    const DOT_RADIUS = 0.6;
    const HOVER_RADIUS = isMobile ? 90 : 140;
    const MOUSE_SMOOTHING = 0.25;

    const STIFFNESS = 0.02;
    const DAMPING = 0.82;
    const MAX_DISPLACEMENT = 20;

    let rawMouseX = -1000;
    let rawMouseY = -1000;
    let smoothMouseX = -1000;
    let smoothMouseY = -1000;
    let animationId: number;

    type Dot = {
      baseX: number; baseY: number;
      x: number; y: number;
      vx: number; vy: number;
      radius: number; opacity: number;
    };

    let dots: Dot[] = [];
    let cols = 0;
    let rows = 0;

    function getColors() {
      const isDark = document.documentElement.getAttribute("data-theme") === "dark"
        || (!document.documentElement.getAttribute("data-theme")
          && window.matchMedia("(prefers-color-scheme: dark)").matches);
      return {
        line: isDark ? "rgba(30, 42, 58, 0.18)" : "rgba(226, 224, 240, 0.3)",
        dot: isDark ? "rgba(30, 42, 58, 0.2)" : "rgba(226, 224, 240, 0.3)",
        glow: isDark ? "167, 139, 250" : "124, 91, 240",
      };
    }

    let colors = getColors();

    function buildGrid(w: number, h: number) {
      dots = [];
      cols = Math.ceil(w / CELL_SIZE) + 1;
      rows = Math.ceil(h / CELL_SIZE) + 1;
      const offsetX = (w % CELL_SIZE) / 2;
      const offsetY = (h % CELL_SIZE) / 2;

      for (let i = 0; i <= cols; i++) {
        for (let j = 0; j <= rows; j++) {
          const x = offsetX + i * CELL_SIZE;
          const y = offsetY + j * CELL_SIZE;
          dots.push({
            baseX: x, baseY: y,
            x, y,
            vx: 0, vy: 0,
            radius: DOT_RADIUS,
            opacity: 0,
          });
        }
      }
    }

    function resize() {
      const dpr = window.devicePixelRatio || 1;
      const w = window.innerWidth;
      const h = window.innerHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      canvas.style.width = `${w}px`;
      canvas.style.height = `${h}px`;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      buildGrid(w, h);
    }

    function update() {
      smoothMouseX += (rawMouseX - smoothMouseX) * MOUSE_SMOOTHING;
      smoothMouseY += (rawMouseY - smoothMouseY) * MOUSE_SMOOTHING;

      for (const dot of dots) {
        const dx = dot.baseX - smoothMouseX;
        const dy = dot.baseY - smoothMouseY;
        const distSq = dx * dx + dy * dy;
        const radiusSq = HOVER_RADIUS * HOVER_RADIUS;

        let targetX = dot.baseX;
        let targetY = dot.baseY;
        let targetOpacity = 0;
        let targetRadius = DOT_RADIUS;

        if (distSq < radiusSq) {
          const dist = Math.sqrt(distSq);
          const force = 1 - (distSq / radiusSq);
          const angle = Math.atan2(dy, dx);
          const displacement = force * MAX_DISPLACEMENT;

          targetX = dot.baseX + Math.cos(angle) * displacement;
          targetY = dot.baseY + Math.sin(angle) * displacement;
          targetOpacity = force * 0.8;
          targetRadius = DOT_RADIUS + force * 2;
        }

        const forceX = (targetX - dot.x) * STIFFNESS;
        const forceY = (targetY - dot.y) * STIFFNESS;
        dot.vx = (dot.vx + forceX) * DAMPING;
        dot.vy = (dot.vy + forceY) * DAMPING;
        dot.x += dot.vx;
        dot.y += dot.vy;

        dot.opacity += (targetOpacity - dot.opacity) * 0.1;
        dot.radius += (targetRadius - dot.radius) * 0.1;
      }
    }

    function draw() {
      const w = window.innerWidth;
      const h = window.innerHeight;
      ctx!.clearRect(0, 0, w, h);

      ctx!.lineWidth = 0.5;
      ctx!.strokeStyle = colors.line;
      const offsetX = (w % CELL_SIZE) / 2;
      const offsetY = (h % CELL_SIZE) / 2;

      ctx!.beginPath();
      for (let i = 0; i <= cols; i++) {
        const x = offsetX + i * CELL_SIZE;
        ctx!.moveTo(x, 0);
        ctx!.lineTo(x, h);
      }
      for (let j = 0; j <= rows; j++) {
        const y = offsetY + j * CELL_SIZE;
        ctx!.moveTo(0, y);
        ctx!.lineTo(w, y);
      }
      ctx!.stroke();

      ctx!.beginPath();
      ctx!.fillStyle = colors.dot;
      for (const dot of dots) {
        if (dot.opacity < 0.01) {
          ctx!.moveTo(dot.baseX + DOT_RADIUS, dot.baseY);
          ctx!.arc(dot.baseX, dot.baseY, DOT_RADIUS, 0, Math.PI * 2);
        }
      }
      ctx!.fill();

      for (const dot of dots) {
        if (dot.opacity >= 0.01) {
          ctx!.beginPath();
          ctx!.fillStyle = `rgba(${colors.glow}, ${dot.opacity})`;
          ctx!.arc(dot.x, dot.y, dot.radius, 0, Math.PI * 2);
          ctx!.fill();
        }
      }
    }

    function animate() {
      update();
      draw();
      animationId = requestAnimationFrame(animate);
    }

    resize();

    if (prefersReducedMotion) {
      draw();
    } else {
      // Listen on document — covers the whole page
      document.addEventListener("mousemove", (e) => {
        rawMouseX = e.clientX;
        rawMouseY = e.clientY;
      });
      document.addEventListener("mouseleave", () => {
        rawMouseX = -1000;
        rawMouseY = -1000;
      });

      document.addEventListener("touchstart", (e) => {
        rawMouseX = e.touches[0].clientX;
        rawMouseY = e.touches[0].clientY;
      }, { passive: true });
      document.addEventListener("touchmove", (e) => {
        rawMouseX = e.touches[0].clientX;
        rawMouseY = e.touches[0].clientY;
      }, { passive: true });
      document.addEventListener("touchend", () => {
        rawMouseX = -1000;
        rawMouseY = -1000;
      }, { passive: true });

      animate();
    }

    window.addEventListener("resize", () => {
      resize();
      if (prefersReducedMotion) draw();
    });

    const themeObserver = new MutationObserver(() => {
      colors = getColors();
      if (prefersReducedMotion) draw();
    });
    themeObserver.observe(document.documentElement, {
      attributes: true, attributeFilter: ["data-theme"],
    });

    document.addEventListener("astro:before-swap", () => {
      cancelAnimationFrame(animationId);
      themeObserver.disconnect();
    }, { once: true });
  }

  initGrid();
  document.addEventListener("astro:page-load", initGrid);
</script>
