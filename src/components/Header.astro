---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";
import { getBase } from "@/utils/getBase";

const { pathname } = Astro.url;

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const fullPath = getBase(path);
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = fullPath.split("/").filter(p => p.trim());
  return currentPath === fullPath || currentPathArray[0] === pathArray[0];
};

const navItems = [
  { label: "Posts", path: "/posts" },
  { label: "Projects", path: "/projects" },
  { label: "Tags", path: "/tags" },
  { label: "About", path: "/about" },
];
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-accent px-3 py-2 text-background rounded-b-lg transition-all focus:top-0"
>
  Skip to content
</a>

<header class="sticky top-0 z-40 w-full">
  <div class="glass">
    <div
      id="top-nav-wrap"
      class="app-layout py-3 relative flex items-center justify-between"
    >
      <!-- Logo -->
      <a
        href={getBase("/")}
        class="text-lg font-bold tracking-tight text-foreground hover:text-accent transition-colors duration-200"
      >
        {SITE.title}<span class="text-accent">.</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden sm:flex items-center gap-0.5">
        {navItems.map(({ label, path }) => (
          <a
            href={getBase(path)}
            class:list={[
              "px-3 py-1.5 text-sm font-medium rounded-lg transition-colors duration-200",
              "hover:text-accent hover:bg-accent/5",
              { "text-accent bg-accent/10": isActive(path) },
              { "text-foreground/70": !isActive(path) },
            ]}
          >
            {label}
          </a>
        ))}

        <!-- Divider -->
        <div class="w-px h-4 bg-border mx-1" aria-hidden="true"></div>

        <!-- Search -->
        <LinkButton
          href={getBase("/search")}
          class:list={[
            "focus-outline flex p-2 rounded-lg transition-colors duration-200 hover:text-accent hover:bg-accent/5",
            { "text-accent": isActive("/search") },
            { "text-foreground/50": !isActive("/search") },
          ]}
          title="Search"
          aria-label="search"
        >
          <IconSearch class="size-[18px]" />
        </LinkButton>

        <!-- Theme toggle -->
        {SITE.lightAndDarkMode && (
          <button
            id="theme-btn"
            class="focus-outline relative size-8 p-2 rounded-lg transition-colors duration-200 hover:text-accent hover:bg-accent/5 text-foreground/50"
            title="Toggles light & dark"
            aria-label="auto"
            aria-live="polite"
          >
            <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
            <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
          </button>
        )}
      </nav>

      <!-- Mobile menu button -->
      <button
        id="menu-btn"
        class="focus-outline p-2 sm:hidden text-foreground/70"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
    </div>

    <!-- Mobile dropdown -->
    <ul
      id="menu-items"
      class:list={[
        "hidden sm:hidden",
        "app-layout pb-4 flex flex-col gap-1",
      ]}
    >
      {navItems.map(({ label, path }) => (
        <li>
          <a
            href={getBase(path)}
            class:list={[
              "block px-3 py-2.5 text-sm font-medium rounded-lg transition-colors duration-200",
              "hover:text-accent hover:bg-accent/5",
              { "text-accent bg-accent/10": isActive(path) },
              { "text-foreground/70": !isActive(path) },
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="flex items-center gap-1 px-1 pt-2 border-t border-border">
        <LinkButton
          href={getBase("/search")}
          class="focus-outline flex p-2.5 rounded-lg transition-colors duration-200 hover:text-accent hover:bg-accent/5 text-foreground/50"
          title="Search"
          aria-label="search"
        >
          <IconSearch class="size-[18px]" />
        </LinkButton>
        {SITE.lightAndDarkMode && (
          <button
            id="theme-btn-mobile"
            class="focus-outline relative size-10 p-2.5 rounded-lg transition-colors duration-200 hover:text-accent hover:bg-accent/5 text-foreground/50"
            title="Toggles light & dark"
            aria-label="auto"
            aria-live="polite"
          >
            <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
            <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
          </button>
        )}
      </li>
    </ul>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();
  document.addEventListener("astro:after-swap", toggleNav);
</script>
